# Environment Variables for HarveySpecter
# Copy this file to .env and fill in your values

# ─── Database ───────────────────────────────────────
DATABASE_URL=postgresql://harvey:harvey123@localhost:5432/harveyspecter

# ─── Gemini AI ──────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-from-aistudio.google.com

# ─── Better Auth ────────────────────────────────────
BETTER_AUTH_SECRET=generate-a-random-32-char-secret-here
BETTER_AUTH_URL=http://localhost:3000

# ─── Backend ────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
BACKEND_URL=http://localhost:8000

# ─── Frontend ───────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
